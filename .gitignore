# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
# The Python build-artifact ``lib/`` rule above is global; un-ignore the
# frontend source subfolder so ``frontend/src/lib/**`` (TypeScript
# helpers like ir_diff.ts) is tracked. Without this negation, hand-
# created TS modules under that path would be silently excluded from
# the repo and only surface as drift at install time.
!frontend/src/lib/
!frontend/src/lib/**
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv
.venv/
.venv310/

# Testing
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Project specific
*.log
.env
.env.local
.env.orig
.env.*
!.env.example
!.env.production.template

# Secret / credential files — NEVER commit
*.pem
*.key
*.p12
*.pfx
credentials.json
service-account*.json
*secret*.json
!config/keycloak/fxlab-realm.json

# Archive (local backups)
.archive/

# Node
node_modules/
frontend/node_modules/
frontend/dist/

# Database files
*.db
*.sqlite3

# Build artifacts and release archives
*.zip

# Binary documents (keep source, not generated docs)
*.docx
*.pdf

# User specification folders.
# `User Spec/` is excluded — operator's working space for spec
# revisions, snapshots, phase plan ZIPs, and personal notes. EXCEPT
# the `Algo Specfication and Examples/` subdirectory, which contains
# the canonical example *.example.json files (strategy_ir,
# experiment_plan, search_space) referenced by:
#   - tests/unit/libs/contracts/test_experiment_plan.py
#   - libs/contracts/experiment_plan.py / strategy_ir.py docstrings
# Without those in CI's fresh checkout, `make verify` fails on the
# canonical-example parse tests (2026-04-25 run #42 surfaced this).
# `Strategy Repo/` is also INCLUDED in the repo for the 5 production
# IR / experiment_plan / search_space fixtures.
# .DS_Store noise inside any of these is excluded by the global
# .DS_Store rule below.
User Spec/*
!User Spec/Algo Specfication and Examples/

# Temporary / debug files
ship.errors.txt

# Claude working files
.claude/

# FUSE mount artifacts
.fuse_hidden*

# Type checking / linting caches
.mypy_cache/
.ruff_cache/
