      "domain": {
        "values": [
          1,
          2,
          3,
          4
        ]
      },
      "default": 3
    },
    {
      "name": "basket_atr_stop_multiple",
      "path": "exit_logic.initial_stop.multiple",
      "type": "float",
      "domain": {
        "values": [
          1.0,
          1.5,
          2.0,
          2.5
        ]
      },
      "default": 2.0
    },
    {
      "name": "equity_stop_pct",
      "path": "exit_logic.equity_stop.threshold_pct",
      "type": "float",
