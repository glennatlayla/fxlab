{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus data source for FXLab metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "FXLab Execution Layer — Orders, Risk Gates, Circuit Breakers, Kill Switch, Reconciliation",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Order Submission Rate",
      "description": "Orders submitted per second by execution mode",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(orders_submitted_total[5m])) by (execution_mode)",
          "legendFormat": "{{execution_mode}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Order Rejection Rate",
      "description": "Orders rejected per second by mode and reason",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(orders_rejected_total[5m])) by (execution_mode, reason)",
          "legendFormat": "{{execution_mode}} / {{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Order Latency (P50 / P95 / P99)",
      "description": "Order submission to broker acknowledgement latency percentiles",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(order_latency_seconds_bucket[5m])) by (le, execution_mode))",
          "legendFormat": "P50 {{execution_mode}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(order_latency_seconds_bucket[5m])) by (le, execution_mode))",
          "legendFormat": "P95 {{execution_mode}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(order_latency_seconds_bucket[5m])) by (le, execution_mode))",
          "legendFormat": "P99 {{execution_mode}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 5, "lineWidth": 2 },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 2.0 }
            ]
          }
        }
      }
    },
    {
      "title": "Broker Request Duration (P95)",
      "description": "Broker adapter API call duration by method",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(broker_request_duration_seconds_bucket[5m])) by (le, adapter, method))",
          "legendFormat": "{{adapter}}.{{method}} P95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        }
      }
    },
    {
      "title": "Risk Gate Evaluations",
      "description": "Risk gate check rate by check name and result (pass/fail)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(rate(risk_gate_checks_total[5m])) by (check_name, result)",
          "legendFormat": "{{check_name}} ({{result}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 50, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "title": "Kill Switch Activations",
      "description": "Total kill switch activations by scope",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(kill_switch_activations_total) by (scope)",
          "legendFormat": "{{scope}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "title": "Kill Switch MTTH (P99)",
      "description": "Mean Time To Halt — 99th percentile in seconds",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(kill_switch_mtth_seconds_bucket[1h])) by (le))",
          "legendFormat": "MTTH P99",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "max": 30,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Reconciliation Runs",
      "description": "Reconciliation run rate by trigger and status",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "sum(rate(reconciliation_runs_total[5m])) by (trigger, status)",
          "legendFormat": "{{trigger}} ({{status}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 }
        }
      }
    },
    {
      "title": "Reconciliation Discrepancies",
      "description": "Discrepancy rate by type (resolved vs unresolved)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sum(rate(reconciliation_discrepancies_total[5m])) by (type)",
          "legendFormat": "{{type}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "drawStyle": "bars", "fillOpacity": 50 },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "title": "Open Positions by Deployment",
      "description": "Current open position count per deployment",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "positions_total",
          "legendFormat": "{{deployment_id}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["fxlab", "execution", "trading"],
  "templating": {
    "list": [
      {
        "name": "execution_mode",
        "type": "query",
        "datasource": "${DS_PROMETHEUS}",
        "query": "label_values(orders_submitted_total, execution_mode)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "FXLab Execution Overview",
  "uid": "fxlab-execution-overview",
  "version": 1
}
