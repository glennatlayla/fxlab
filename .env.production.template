# ===========================================================================
# FXLab Production Environment Configuration
# ===========================================================================
#
# Copy this file to .env and set all REQUIRED values before running install.sh.
#
#   cp .env.production.template .env
#   nano .env    # Set passwords and secrets
#
# IMPORTANT: Never commit the .env file to version control.
#
# NOTE: install.sh auto-generates POSTGRES_PASSWORD, JWT_SECRET_KEY, and
# CORS_ALLOWED_ORIGINS on first run if they are set to CHANGE_ME or missing.
# ===========================================================================

# ---------------------------------------------------------------------------
# REQUIRED — The installer will fail if these are not set
# ---------------------------------------------------------------------------

# PostgreSQL password. Must be at least 16 characters.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(24))"
POSTGRES_PASSWORD=CHANGE_ME

# JWT signing key. Must be at least 32 bytes.
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_ME

# ---------------------------------------------------------------------------
# CORS — Allowed frontend origins (comma-separated)
# ---------------------------------------------------------------------------
# install.sh auto-detects the server IP and sets this on first run.
# After install, edit .env to add custom domains or HTTPS origins.
# Example: http://192.168.1.50,https://trading.example.com
CORS_ALLOWED_ORIGINS=CHANGE_ME

# ---------------------------------------------------------------------------
# OPTIONAL — Sensible defaults are provided
# ---------------------------------------------------------------------------

# Runtime environment (do not change for production)
ENVIRONMENT=production

# PostgreSQL connection
POSTGRES_USER=fxlab
POSTGRES_DB=fxlab

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=WARNING

# ---------------------------------------------------------------------------
# Redis Configuration
# ---------------------------------------------------------------------------
# Internal Docker network URL for the Redis service.
# Override only if using an external Redis (e.g., AWS ElastiCache, Azure Cache).
REDIS_URL=redis://redis:6379/0

# Rate limiting backend: "memory" (single-worker) or "redis" (production).
RATE_LIMIT_BACKEND=redis

# Login attempt tracking backend: "memory" or "redis".
LOGIN_TRACKER_BACKEND=redis

# ---------------------------------------------------------------------------
# Database Connection Pool Tuning
# ---------------------------------------------------------------------------
# These control the SQLAlchemy connection pool for PostgreSQL.
# Defaults are tuned for 2+ Uvicorn workers under moderate load.

# DB_POOL_SIZE=20          # Connections kept open per worker (default: 20)
# DB_POOL_OVERFLOW=20      # Extra connections allowed under spike (default: 20)
# DB_POOL_TIMEOUT=30       # Seconds to wait for a connection (default: 30)
# DB_STATEMENT_TIMEOUT_MS=30000  # Kill queries after N ms (default: 30000)

# ---------------------------------------------------------------------------
# Networking — Ports exposed on the host machine
# ---------------------------------------------------------------------------

# HTTP port for the Nginx edge proxy (default: 80)
FXLAB_HTTP_PORT=80

# HTTPS port for the Nginx edge proxy (default: 443)
FXLAB_HTTPS_PORT=443

# ---------------------------------------------------------------------------
# Alerting — Webhook endpoints for Prometheus alerts
# ---------------------------------------------------------------------------
# Alertmanager routes firing alerts to these URLs via HTTP POST.
# Default: routes back to FXLab API's alert-webhook endpoint.
# Override for external integrations (PagerDuty, Slack, custom endpoints).

# ALERTMANAGER_WEBHOOK_URL=http://fxlab-api:8000/observability/alert-webhook
# ALERTMANAGER_CRITICAL_WEBHOOK_URL=http://fxlab-api:8000/observability/alert-webhook

# ---------------------------------------------------------------------------
# Optional — Keycloak Identity Provider
# ---------------------------------------------------------------------------
# Uncomment and configure to enable Keycloak RS256 authentication.
# When disabled, FXLab uses self-rolled HS256 JWT authentication.

# KEYCLOAK_URL=http://keycloak:8080
# KEYCLOAK_REALM=fxlab
# KEYCLOAK_CLIENT_ID=fxlab-api
# KEYCLOAK_ADMIN_CLIENT_SECRET=
# KEYCLOAK_ADMIN=admin
# KEYCLOAK_ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# Execution Mode Enforcement — Production Safety Feature
# ---------------------------------------------------------------------------
# Comma-separated list of execution modes allowed by LiveExecutionService.
# Default (commented): "shadow,paper,live" — allows all modes.
# Recommended for production: "shadow,paper" — disables live trading globally.
#
# This is an environment-level kill switch for live order execution.
# If ALLOWED_EXECUTION_MODES does not contain "live", all live order submissions
# will raise ConfigError before any persistence or broker submission occurs.
#
# CRITICAL: Before setting this to "shadow,paper,live" in production, ensure:
# - All broker adapters are properly configured and tested.
# - All deployment configurations are correct (execution_mode matches adapter).
# - Risk gates and kill switches are active and working.
# - Monitoring and alerting are in place for execution errors.
#
# ALLOWED_EXECUTION_MODES=shadow,paper

# ---------------------------------------------------------------------------
# Optional — Secret Provider Configuration (SOC2/Financial Compliance)
# ---------------------------------------------------------------------------
# Selects where secrets (API keys, DB passwords, etc.) are retrieved from.
# Default: "env" (read from environment variables — suitable for Docker secrets).
#
# Options:
#   "env"    — Read from environment variables (RECOMMENDED for Docker secrets)
#   "azure"  — Read from Azure Key Vault (RECOMMENDED for Azure deployments)
#
# SECRET_PROVIDER=env

# Azure Key Vault (when SECRET_PROVIDER=azure)
# AZURE_KEYVAULT_URL=https://fxlab-prod.vault.azure.net  # Key Vault URL (REQUIRED)
# SECRET_PREFIX=fxlab-                                    # Prefix for secret names (default: fxlab-)
# Authentication via DefaultAzureCredential (supports, in order):
#   - Managed Identity (RECOMMENDED for Azure VMs, AKS, App Service)
#   - Azure CLI credentials (local development)
#   - Environment variables: AZURE_CLIENT_ID, AZURE_CLIENT_SECRET, AZURE_TENANT_ID
#   - Workload Identity (AKS pods)

# ---------------------------------------------------------------------------
# Optional — Observability
# ---------------------------------------------------------------------------
# Uncomment to enable distributed tracing via Jaeger/OTLP.

# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
# OTEL_SERVICE_NAME=fxlab-api
# OTEL_TRACES_SAMPLER_ARG=0.1
