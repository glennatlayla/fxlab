# FXLab Environment Configuration
# Copy to .env and customize for your environment

# Service Configuration
LOG_LEVEL=INFO

# ENVIRONMENT controls repository implementation selection:
#   "test"         → in-memory mock repositories (pytest default when var is unset)
#   "development"  → SQL repositories against local PostgreSQL
#   "production"   → SQL repositories against production PostgreSQL
# IMPORTANT: The production Dockerfile hard-codes ENVIRONMENT=production via ARG/ENV
# so containers never accidentally fall back to in-memory mocks.
# Never deploy a container without this variable explicitly set.
ENVIRONMENT=development

# Database (M2+)
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432
# POSTGRES_DB=fxlab
# POSTGRES_USER=fxlab
# POSTGRES_PASSWORD=change-me-in-production

# Redis (M4+)
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=

# Login brute-force protection backend.
# "memory" (default) — per-worker only, suitable for single-worker dev.
# "redis"           — cross-worker shared lockout (requires REDIS_URL).
# In production with ENVIRONMENT=production and LOGIN_TRACKER_BACKEND=redis,
# missing REDIS_URL or unreachable Redis will crash the worker at startup (fail-closed).
# LOGIN_TRACKER_BACKEND=redis

# Object Storage (M5+)
# S3_ENDPOINT=http://minio:9000
# S3_ACCESS_KEY=minio-access-key
# S3_SECRET_KEY=minio-secret-key
# S3_BUCKET=fxlab-artifacts

# CORS — comma-separated list of allowed frontend origins.
# Default (localhost:3000,localhost:5173) is for local development only.
# In production: set to your actual frontend domain(s).
# Example: CORS_ALLOWED_ORIGINS=https://app.fxlab.example.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Database connection string (overrides alembic.ini sqlalchemy.url).
# Required for production. Alembic migrations read this automatically via env.py.
# Use sslmode=require for production: DATABASE_URL=postgresql://fxlab:CHANGE-ME@host:5432/fxlab?sslmode=require
# DATABASE_URL=postgresql://fxlab:CHANGE-ME@postgres:5432/fxlab

# Database connection pool (PostgreSQL only; ignored for SQLite).
# These control SQLAlchemy's QueuePool behavior. Non-positive or non-numeric
# values are rejected with a CRITICAL log and the default is used instead.
# DB_POOL_SIZE=5            # Max persistent connections in the pool
# DB_POOL_OVERFLOW=10       # Max additional connections beyond pool_size
# DB_POOL_TIMEOUT=30        # Seconds to wait for a connection before raising

# SQL echo (debug only — never enable in production)
# SQL_ECHO=false

# Auth (M14-T2) — REQUIRED in production
# Generate a 32+ byte random secret: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# JWT_SECRET_KEY=<REQUIRED: 32+ byte random secret>
# JWT_ALGORITHM=HS256
# JWT_EXPIRATION_MINUTES=60
# JWT_MAX_TOKEN_BYTES=16384

# Rate limiting
# RATE_LIMIT_GOVERNANCE=20      # Governance endpoints: requests per minute per IP
# RATE_LIMIT_DEFAULT=100        # All other endpoints: requests per minute per IP

# Request body size limit (bytes). Default: 524288 (512 KB).
# MAX_REQUEST_BODY_BYTES=524288

# Keycloak Identity Provider (M14-T8b)
# When KEYCLOAK_URL is set, auth.py validates RS256 tokens from Keycloak instead
# of issuing/validating self-rolled HS256 tokens. KEYCLOAK_URL unset → HS256 fallback.
# KEYCLOAK_URL=http://keycloak:8080
# KEYCLOAK_REALM=fxlab
# KEYCLOAK_CLIENT_ID=fxlab-api
# KEYCLOAK_ADMIN_CLIENT_SECRET=<from Keycloak admin console>
# KEYCLOAK_ADMIN=admin
# KEYCLOAK_ADMIN_PASSWORD=<REQUIRED for docker-compose: Keycloak admin console password>

# Observability (M11+)
# PROMETHEUS_PORT=9090
# GRAFANA_PORT=3000

# Execution Mode Enforcement (Phase 6, M3 — Production Safety)
# Comma-separated list of execution modes allowed by LiveExecutionService.
# Set to "shadow,paper" to disable live trading globally.
# Set to "shadow,paper,live" (default) to allow live order submission.
# IMPORTANT: In production, set this to "shadow,paper" unless live trading
# is explicitly enabled and tested. This is a kill switch for the entire
# live trading system.
# ALLOWED_EXECUTION_MODES=shadow,paper,live

# OpenTelemetry Distributed Tracing (M16)
# Set OTEL_EXPORTER_OTLP_ENDPOINT to enable distributed tracing.
# Leave empty/unset to disable tracing (no-op, zero overhead).
# OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
# OTEL_SERVICE_NAME=fxlab-api
# OTEL_TRACES_SAMPLER=parentbased_traceidratio
# OTEL_TRACES_SAMPLER_ARG=0.1   # 10% sampling in production, 1.0 for development

# Secret Provider Configuration (SOC2 Compliance)
# Selects where secrets (API keys, DB passwords, etc.) are retrieved from.
# Options:
#   "env"    (default) — Read from environment variables and os.environ
#   "azure"  — Read from Azure Key Vault
# SECRET_PROVIDER=env

# Azure Key Vault Configuration (when SECRET_PROVIDER=azure)
# AZURE_KEYVAULT_URL=https://fxlab-prod.vault.azure.net  # Key Vault URL (required)
# SECRET_PREFIX=fxlab-                                    # Prefix for secret names (default: fxlab-)
# Authentication via DefaultAzureCredential (managed identity, CLI, env vars)
