# =============================================================================
# .dockerignore — FXLab Production Image
#
# Excludes test files, development artifacts, secrets, and documentation
# from Docker build context to reduce image size and attack surface.
# =============================================================================

# Version control
.git
.gitignore

# Test suites and fixtures
tests/
pytest.ini
.coveragerc
.coverage
htmlcov/
coverage.xml

# Development environment
.venv/
.env
.env.*
*.env
__pycache__/
*.pyc
*.pyo
*.egg-info/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# Archives and backups
.archive/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~

# Documentation (not needed in runtime image)
*.md
docs/
LICENSE

# Docker files (prevent recursive context)
Dockerfile
docker-compose.yml
docker-compose*.yml
.dockerignore

# CI/CD configuration
.github/
.gitlab-ci.yml
Makefile

# Claude / AI working files
.claude/
CLAUDE.md

# Frontend build artifacts (API image doesn't need these)
frontend/node_modules/
frontend/dist/

# OS files
.DS_Store
Thumbs.db
