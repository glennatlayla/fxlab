import subprocess
import time

def docker_compose_file(project_root):
    """Return path to docker-compose.yml."""
    compose_file = project_root / "docker-compose.yml"
    return compose_file


def api_base_url():
    """Base URL for API service in docker-compose."""
    return "http://localhost:8000"


def web_base_url():
    """Base URL for web service in docker-compose."""
    return "http://localhost:3000"


def health_check_timeout():
    """Default timeout for health check retries (seconds)."""
    return 30


def health_check_interval():
    """Default interval between health check retries (seconds)."""
    return 1


def pytest_configure(config):
    """Configure pytest with custom markers."""
    config.addinivalue_line(
        "markers", "integration: mark test as integration test requiring Docker"
    )
    config.addinivalue_line(
        "markers", "unit: mark test as unit test (no external dependencies)"
    )
