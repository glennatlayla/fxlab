from ulid import ULID

# -- merged imports --
import sys
from pathlib import Path

def project_root() -> Path:
    """Project root directory."""
    return PROJECT_ROOT


def test_data_dir(project_root: Path) -> Path:
    """Test data directory."""
    data_dir = project_root / "tests" / "fixtures" / "data"
    data_dir.mkdir(parents=True, exist_ok=True)
    return data_dir


def fixture_csv_dir(project_root: Path) -> Path:
    """Directory containing fixture CSV files."""
    csv_dir = project_root / "tests" / "fixtures" / "data"
    csv_dir.mkdir(parents=True, exist_ok=True)
    return csv_dir


def mock_env(monkeypatch):
    """Mock environment variables for testing."""
    test_env = {
        "ENVIRONMENT": "test",
        "LOG_LEVEL": "DEBUG",
        "DB_HOST": "localhost",
        "DB_PORT": "5432",
        "DB_NAME": "fxlab_test",
        "DB_USER": "test",
        "DB_PASSWORD": "test",
        "REDIS_HOST": "localhost",
        "REDIS_PORT": "6379",
        "MINIO_HOST": "localhost",
        "MINIO_PORT": "9000",
        "MINIO_ACCESS_KEY": "minioadmin",
        "MINIO_SECRET_KEY": "minioadmin",
    }
    for key, value in test_env.items():
        monkeypatch.setenv(key, value)
    return test_env


def sample_strategy_code() -> str:
    """Sample strategy source code for testing."""
    return """
def initialize(context):
    context.symbol = "EURUSD"
    context.period = "1h"

def handle_data(context, data):
    price = data.current(context.symbol, "close")
    if price > context.get("last_price", 0):
        context.order(context.symbol, 100)
    context.last_price = price
"""

def frontend_root(project_root):
    """Get frontend directory."""
    return project_root / "frontend"


def backend_root(project_root):
    """Get backend services directory."""
    return project_root / "services"

