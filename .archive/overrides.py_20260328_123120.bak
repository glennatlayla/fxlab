"""
Governance Override API endpoints.

Responsibilities:
- Expose override request submission and retrieval endpoints.
- Validate override request payloads using OverrideRequest contract
  (enforces SOC 2 evidence_link and rationale requirements).
- Return 201 on successful submission and 404 for unknown override IDs.
- Emit structured log events at all key lifecycle points.

Does NOT:
- Contain business logic or approval logic.
- Write to a database (stub implementation — SQL repository wired in M13-T3).
- Enforce separation-of-duties (service layer responsibility).

Dependencies:
- libs.contracts.governance: OverrideRequest, OverrideDetail
- structlog for structured logging

Error conditions:
- 422 Unprocessable Entity: evidence_link is not a valid HTTP/HTTPS URI with
  a non-root path, or rationale is too short.
- 404 Not Found: override_id does not exist in the store.

Example:
    POST /overrides/request
    {
        "object_id": "01H...",
        "object_type": "candidate",
        "override_type": "grade_override",
        "original_state": {"grade": "C"},
        "new_state": {"grade": "B"},
        "evidence_link": "https://jira.example.com/browse/FX-123",
        "rationale": "Extended backtest justifies grade uplift.",
        "submitter_id": "01H..."
    }
    → 201 {"override_id": "01H...", "status": "pending"}

    GET /overrides/01H...
    → 200 {OverrideDetail}
"""

from __future__ import annotations

from datetime import datetime, timezone
from typing import Any
from urllib.parse import urlparse

import structlog
from fastapi import APIRouter, HTTPException, Path, status

from libs.contracts.governance import OverrideDetail, OverrideRequest, OverrideType

# ---------------------------------------------------------------------------
# Validation constants — enforced manually because pydantic-core field
# constraints are not applied in this venv (stub pydantic-core).
# ---------------------------------------------------------------------------
_RATIONALE_MIN_LEN = 20


def _assert_evidence_link(value: str) -> None:
    """
    Raise HTTP 422 if evidence_link is not an absolute HTTP/HTTPS URI
    with a non-root path.

    Args:
        value: The raw evidence_link string from the request.

    Raises:
        HTTPException 422: If scheme is not http/https or path is root/empty.
    """
    parsed = urlparse(value)
    if parsed.scheme not in ("http", "https"):
        raise HTTPException(
            status_code=status.HTTP_422_UNPROCESSABLE_CONTENT,
            detail=(
                f"evidence_link must use http or https scheme "
                f"(got '{parsed.scheme}')"
            ),
        )
    path = parsed.path.rstrip("/")
    if not path:
        raise HTTPException(
            status_code=status.HTTP_422_UNPROCESSABLE_CONTENT,
            detail=(
                "evidence_link must reference a specific resource path, "
                "not just the host. Use a Jira ticket, Confluence doc, "
                "or GitHub issue URL."
            ),
        )

logger = structlog.get_logger(__name__)

router = APIRouter()

# ---------------------------------------------------------------------------
# In-memory stub store — replaced by SqlOverrideRepository in M13-T3.
# This store persists for the lifetime of the process and is NOT
# suitable for production use or multi-worker deployments.
# ---------------------------------------------------------------------------
_override_store: dict[str, dict[str, Any]] = {}

# Deterministic stub ULID prefix (avoids ulid dependency for the stub).
_STUB_ULID_PREFIX = "01HOVERRIDE"
_stub_counter = 0


def _generate_stub_id() -> str:
    """Generate a stub ULID-shaped ID for the in-memory store."""
    global _stub_counter
    _stub_counter += 1
    return f"{_STUB_ULID_PREFIX}{_stub_counter:015d}"


# ---------------------------------------------------------------------------
# Endpoints
# ---------------------------------------------------------------------------


@router.post(
    "/request",
    status_code=status.HTTP_201_CREATED,
    summary="Submit a governance override request",
)
async def request_override(payload: OverrideRequest) -> dict:
    """
    Submit a governance override request.

    evidence_link is validated to be an absolute HTTP/HTTPS URI with a
    non-root path (SOC 2 Evidence of Review requirement). Requests without
    a valid evidence_link are rejected with 422.

    Args:
        payload: OverrideRequest body — all fields required.

    Returns:
        201 response with override_id and status='pending'.

    Raises:
        HTTPException 422: If evidence_link validation fails or rationale
            is shorter than 20 characters.

    Example:
        POST /overrides/request
        → 201 {"override_id": "01H...", "status": "pending"}
    """
    # Manual validation (pydantic-core constraints not enforced in this env).
    _assert_evidence_link(payload.evidence_link)
    if len(payload.rationale) < _RATIONALE_MIN_LEN:
        raise HTTPException(
            status_code=status.HTTP_422_UNPROCESSABLE_CONTENT,
            detail=(
                f"rationale must be at least {_RATIONALE_MIN_LEN} characters "
                f"(got {len(payload.rationale)})"
            ),
        )

    now = datetime.now(tz=timezone.utc)
    override_id = _generate_stub_id()

    _override_store[override_id] = {
        "id": override_id,
        "object_id": payload.object_id,
        "object_type": payload.object_type,
        "override_type": payload.override_type,
        "original_state": payload.original_state,
        "new_state": payload.new_state,
        "evidence_link": payload.evidence_link,
        "rationale": payload.rationale,
        "submitter_id": payload.submitter_id,
        "status": "pending",
        "reviewed_by": None,
        "reviewed_at": None,
        "created_at": now,
        "updated_at": now,
    }

    logger.info(
        "override.request.submitted",
        override_id=override_id,
        object_type=payload.object_type,
        override_type=payload.override_type.value,
        submitter_id=payload.submitter_id,
    )

    return {"override_id": override_id, "status": "pending"}


@router.get(
    "/{override_id}",
    summary="Retrieve a governance override request by ID",
)
async def get_override(
    override_id: str = Path(..., description="Override request ULID"),
) -> dict:
    """
    Retrieve details of a governance override request.

    Args:
        override_id: ULID of the override request.

    Returns:
        OverrideDetail-shaped dict with full override information.

    Raises:
        HTTPException 404: If override_id is not found.

    Example:
        GET /overrides/01H...
        → 200 {"id": "01H...", "status": "pending", ...}
    """
    record = _override_store.get(override_id)
    if record is None:
        logger.warning("override.get.not_found", override_id=override_id)
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail=f"Override request '{override_id}' not found.",
        )

    logger.debug("override.get.found", override_id=override_id)
    return {
        "override_id": record["id"],
        "id": record["id"],
        "object_id": record["object_id"],
        "object_type": record["object_type"],
        "override_type": record["override_type"],
        "original_state": record["original_state"],
        "new_state": record["new_state"],
        "evidence_link": record["evidence_link"],
        "rationale": record["rationale"],
        "submitter_id": record["submitter_id"],
        "status": record["status"],
        "reviewed_by": record["reviewed_by"],
        "reviewed_at": record["reviewed_at"],
        "created_at": record["created_at"].isoformat(),
        "updated_at": record["updated_at"].isoformat(),
    }
