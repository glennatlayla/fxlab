@pytest.fixture
def temp_project_root(tmp_path: Path) -> Generator[Path, None, None]:
    """Provide a temporary project root for file system tests."""
    # Create minimal structure
    services = tmp_path / "services"
    services.mkdir()
    
    libs = tmp_path / "libs"
    libs.mkdir()
    
    tests = tmp_path / "tests"
    tests.mkdir()
    
    yield tmp_path

