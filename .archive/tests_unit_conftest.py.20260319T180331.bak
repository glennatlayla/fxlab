def mock_phase1_artifact_store() -> Mock:
    """Mock Phase 1 artifact storage system."""
    store = MagicMock()
    store.store.return_value = "artifact-ulid-123"
    store.retrieve.return_value = b"mock-content"
    store.exists.return_value = True
    return store


