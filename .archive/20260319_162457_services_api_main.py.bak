# -- merged (accumulator): services/api/main.py --
def submit_promotion_request(request) -> dict:
    """
    Submit promotion request to background job queue.
    
    This function creates audit events and enqueues the promotion job.
    In tests, this function is mocked to avoid actual queue/audit dependencies.
    """
    job_id = str(ULID())
    
    logger.info(
        "promotion.job.created",
        job_id=job_id,
        candidate_id=request.candidate_id,
    )
    
    # Create audit event (stub - would use actual audit repository)
    logger.info(
        "audit.event.created",
        event_type="promotion_requested",
        job_id=job_id,
        candidate_id=request.candidate_id,
        requester_id=request.requester_id,
    )
    
    return {
        "job_id": job_id,
        "status": "pending"
    }

