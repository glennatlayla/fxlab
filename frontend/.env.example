# =============================================================================
# FXLab Frontend — Environment Variables
# =============================================================================
# Copy this file to .env and fill in values for your environment.
# All variables prefixed with VITE_ are exposed to the browser at build time.
# NEVER commit secrets to .env — this file (.env.example) is safe to commit.
# =============================================================================

# ---------------------------------------------------------------------------
# API Configuration
# ---------------------------------------------------------------------------

# Base URL for the FXLab backend API.
# Required in production. Falls back to http://localhost:8000 in development.
VITE_API_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------

# Percentage of token lifetime remaining before triggering a silent refresh.
# Default: 0.15 (15% of token TTL remaining triggers refresh).
VITE_AUTH_REFRESH_BUFFER_PERCENT=0.15

# Maximum number of login attempts before temporary lockout.
# Default: 5
VITE_AUTH_MAX_LOGIN_ATTEMPTS=5

# Duration in seconds to lock out a user after exceeding max login attempts.
# Default: 30
VITE_AUTH_LOCKOUT_DURATION_SECONDS=30

# ---------------------------------------------------------------------------
# Authentication Mode
# ---------------------------------------------------------------------------

# Auth mode: "local" (default) uses email/password JWT flow.
# "oidc" uses Keycloak OIDC Authorization Code Flow with PKCE.
VITE_AUTH_MODE=local

# ---------------------------------------------------------------------------
# OIDC Configuration (only used when VITE_AUTH_MODE=oidc)
# ---------------------------------------------------------------------------

# Keycloak OIDC authority URL (issuer).
# Example: https://keycloak.fxlab.internal/realms/fxlab
VITE_OIDC_AUTHORITY=

# OIDC client ID registered in Keycloak.
# Must be a public client (no client secret) with PKCE enabled.
VITE_OIDC_CLIENT_ID=

# Redirect URI after Keycloak login. Must match Keycloak client config.
# Defaults to {origin}/callback if unset.
VITE_OIDC_REDIRECT_URI=

# Redirect URI after Keycloak logout.
# Defaults to {origin} if unset.
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=

# OIDC scopes to request. Default: "openid profile email"
VITE_OIDC_SCOPE=openid profile email

# ---------------------------------------------------------------------------
# Observability — Sentry
# ---------------------------------------------------------------------------

# Sentry DSN for error tracking.
# Optional in development, strongly recommended in production.
# Obtain from: https://sentry.io → Project Settings → Client Keys (DSN)
VITE_SENTRY_DSN=

# Application version string for Sentry release tracking.
# Typically set by CI from package.json version or git tag.
VITE_APP_VERSION=0.0.0
