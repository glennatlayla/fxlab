  <section
    aria-label="Ambiguities & Defaults"
    class="rounded-lg border border-surface-200 bg-white p-4"
    data-testid="ir-section-ambiguities"
  >
    <h2
      class="mb-3 text-lg font-semibold text-surface-900"
    >
      <span
        class="mr-2 inline-block rounded bg-brand-100 px-2 py-0.5 text-xs font-bold text-brand-800"
      >
        L
      </span>
      Ambiguities & Defaults
    </h2>
    <div
      class="text-sm text-surface-800"
    >
      <details>
        <summary
          class="cursor-pointer text-xs font-medium uppercase tracking-wider text-surface-500"
        >
          Show 
          6
           item
          s
        </summary>
        <dl
          class="mt-2 space-y-2"
        >
          <div
            class="border-l-2 border-surface-200 pl-3"
          >
            <dt
              class="text-xs font-semibold text-surface-700"
            >
              breakout_reference_rule
            </dt>
            <dd
              class="mt-1 text-sm text-surface-800"
            >
              Use completed-bar breakout beyond rolling channel; no intrabar stop entries assumed.
            </dd>
          </div>
          <div
            class="border-l-2 border-surface-200 pl-3"
          >
            <dt
              class="text-xs font-semibold text-surface-700"
            >
              trend_filter_choice
            </dt>
            <dd
              class="mt-1 text-sm text-surface-800"
            >
              200 EMA and ADX filters added as explicit assumptions to reduce noise in FX daily breakouts.
            </dd>
          </div>
          <div
            class="border-l-2 border-surface-200 pl-3"
          >
            <dt
              class="text-xs font-semibold text-surface-700"
            >
              same_bar_conflict_rule
            </dt>
