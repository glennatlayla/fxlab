  <section
    aria-label="Ambiguities & Defaults"
    class="rounded-lg border border-surface-200 bg-white p-4"
    data-testid="ir-section-ambiguities"
  >
    <h2
      class="mb-3 text-lg font-semibold text-surface-900"
    >
      <span
        class="mr-2 inline-block rounded bg-brand-100 px-2 py-0.5 text-xs font-bold text-brand-800"
      >
        L
      </span>
      Ambiguities & Defaults
    </h2>
    <div
      class="text-sm text-surface-800"
    >
      <details>
        <summary
          class="cursor-pointer text-xs font-medium uppercase tracking-wider text-surface-500"
        >
          Show 
          6
           item
          s
        </summary>
        <dl
          class="mt-2 space-y-2"
        >
          <div
            class="border-l-2 border-surface-200 pl-3"
          >
            <dt
              class="text-xs font-semibold text-surface-700"
            >
              seasonal_effect_choice
            </dt>
            <dd
              class="mt-1 text-sm text-surface-800"
            >
              Turn-of-month basket selected as an explicit FX calendar-effect research candidate because public descriptions of seasonal strategies are generic rather than FX-specific.
            </dd>
          </div>
          <div
            class="border-l-2 border-surface-200 pl-3"
          >
            <dt
              class="text-xs font-semibold text-surface-700"
            >
              basket_direction_choice
            </dt>
            <dd
              class="mt-1 text-sm text-surface-800"
            >
              USD-short bias basket used as a testable hypothesis, not a claimed universal edge.
            </dd>
          </div>
          <div
            class="border-l-2 border-surface-200 pl-3"
          >
            <dt
              class="text-xs font-semibold text-surface-700"
            >
              same_bar_conflict_rule
            </dt>
            <dd
              class="mt-1 text-sm text-surface-800"
            >
              apply exit priority list
            </dd>
          </div>
          <div
            class="border-l-2 border-surface-200 pl-3"
          >
            <dt
              class="text-xs font-semibold text-surface-700"
            >
              indicator_alignment_rule
            </dt>
            <dd
              class="mt-1 text-sm text-surface-800"
            >
              all calculations use completed bars only
            </dd>
          </div>
          <div
            class="border-l-2 border-surface-200 pl-3"
          >
            <dt
              class="text-xs font-semibold text-surface-700"
            >
              missing_data_fallback
            </dt>
            <dd
              class="mt-1 text-sm text-surface-800"
            >
              skip affected month event
            </dd>
          </div>
          <div
            class="border-l-2 border-surface-200 pl-3"
          >
            <dt
              class="text-xs font-semibold text-surface-700"
            >
              notes
            </dt>
            <dd
              class="mt-1 text-sm text-surface-800"
            >
              <ul
                class="list-inside list-disc space-y-1"
              >
                <li>
                  This artifact is best treated as a hypothesis template for FXLab, not a vetted production strategy.
                </li>
              </ul>
            </dd>
          </div>
        </dl>
      </details>
    </div>
  </section>
</div>
`;
